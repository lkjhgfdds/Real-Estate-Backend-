# ============================================================
# Real Estate Pro Backend — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/real-estate-pro?retryWrites=true&w=majority
# Example: mongodb+srv://myuser:mypass@cluster0.abcd1.mongodb.net/real-estate-pro?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_secret_here
JWT_EXPIRES_IN=15m

# MUST be different from JWT_SECRET — generate separately!
JWT_REFRESH_SECRET=another_completely_different_64_char_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Example Upstash: rediss://user:pass@host:port

# ── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (SMTP) ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
# For Gmail: use App Password (not your real password)
# Guide: https://support.google.com/accounts/answer/185833

# ── App URLs ─────────────────────────────────────────────────
# Used in email links and CORS
CLIENT_URL=http://localhost:5173
# Production example: https://your-frontend.vercel.app

# ── Rate Limiting ────────────────────────────────────────────
# Optional overrides (defaults are set in code)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# Generate a 64-character hex string for encryption
ENCRYPTION_KEY=
